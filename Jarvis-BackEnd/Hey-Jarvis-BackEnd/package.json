{
    "type": "module",
    "scripts": {
        "dev": "nodemon index.js",
        "build:server": "tsup index.js --format esm --platform node --target node20 --out-dir dist --clean",
        "build:worker": "tsup utils/ScheduleComponents/workers/accountabilityWorker.js --format esm --platform node --target node20 --out-dir dist",
        "build:all": "npm run build:server && npm run build:worker",
